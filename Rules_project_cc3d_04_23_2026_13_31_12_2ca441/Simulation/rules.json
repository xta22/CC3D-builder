{
  "rules": [
    {
      "id": "1",
      "target": "CellA",
      "behaviour": "differentiate",
      "cases": [
        {
          "when": {
            "condition_type": "Environment",
            "params": {
              "operator": ">",
              "threshold": 3.0,
              "field_name": "Substrate"
            }
          },
          "apply": {
            "mode": "division",
            "parent_type": "CellB",
            "child_type": "CellB",
            "volume_ratio": 0.5,
            "placement": {
              "type": "random"
            }
          }
        }
      ],
      "once": false,
      "debug": false,
      "triggered": false
    }
  ],
  "celltype_params": {
    "Cell": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    },
    "CellA": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    },
    "CellB": {
      "targetVolume": 100.0,
      "lambdaVolume": 10.0
    }
  },
  "field_params": {
    "Substrate": {
      "solver": "DiffusionSolverFE",
      "diffusion_constant": 0.1,
      "decay_constant": 1e-05,
      "initial_expression": "0.0",
      "boundary_conditions": {
        "X": {
          "type": "ConstantValue",
          "min_val": 5.0,
          "max_val": 0.0
        },
        "Y": {
          "type": "Periodic",
          "min_val": 0.0,
          "max_val": 0.0
        },
        "Z": {
          "type": "Periodic",
          "min_val": 0.0,
          "max_val": 0.0
        }
      },
      "chemotaxis": [
        {
          "CellType": "CellA",
          "Lambda": 100.0,
          "Type": "regular",
          "SatCoef": 0.0
        }
      ],
      "python_secretion": false
    },
    "Oxygen": {
      "solver": "DiffusionSolverFE",
      "diffusion_constant": 0.9,
      "decay_constant": 1e-05,
      "initial_expression": "x/100",
      "boundary_conditions": {},
      "chemotaxis": {
        "Cell": 1000.0
      },
      "python_secretion": false
    }
  }
}
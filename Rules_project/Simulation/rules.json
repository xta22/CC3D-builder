{
  "rules": [
    {
      "behaviour": "growth",
      "id": "1",
      "target": "CellA",
      "when": {
        "condition_type": "TimeWindow",
        "params": {
          "start_mcs": 0,
          "end_mcs": 1000
        }
      },
      "apply": {
        "model": "linear",
        "regulator": NaN,
        "parameters": {
          "alpha": 0.5
        }
      },
      "once": true,
      "debug": false
    },
    {
      "behaviour": "growth",
      "id": "2",
      "target": "CellB",
      "when": {
        "condition_type": "Environment",
        "params": {
          "operator": "<",
          "threshold": 0.2,
          "field_name": "Oxygen"
        }
      },
      "apply": {
        "model": "hill",
        "regulator": "Oxygen",
        "parameters": {
          "y_min": 0.0,
          "y_max": 2.0,
          "k": 0.5,
          "n": 4.0
        }
      },
      "once": false,
      "debug": true
    },
    {
      "behaviour": "growth",
      "id": "3",
      "target": "CellA",
      "when": {
        "condition_type": "Morphology_Elongation",
        "params": {
          "operator": ">",
          "threshold": 2.0
        }
      },
      "apply": {
        "model": "expression",
        "regulator": "elongation",
        "parameters": {
          "expression": "0.01 * Oxygen"
        }
      },
      "once": false,
      "debug": false
    }
  ],
  "celltype_params": {
    "Cell": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    },
    "CellA": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    },
    "CellB": {
      "targetVolume": 49.0,
      "lambdaVolume": 10.0,
      "initial_count": 5,
      "should_initialize": true
    }
  },
  "field_params": {
    "Oxygen": {
      "solver": "DiffusionSolverFE",
      "diffusion_constant": 0.9,
      "decay_constant": 1e-05,
      "initial_expression": "x/100",
      "boundary_conditions": {
        "X": {
          "type": "ConstantValue",
          "min_val": 0.0,
          "max_val": 0.0
        },
        "Y": {
          "type": "ConstantDerivative",
          "min_val": 0.0,
          "max_val": 0.0
        }
      },
      "chemotaxis": [
        {
          "cell_type": "Cell",
          "lambda": 1000.0,
          "mode": "simple",
          "sat_coef": 0.0
        }
      ]
    }
  }
}
{
  "rules": [
    {
      "id": "1",
      "target": "Cell",
      "behaviour": "differentiate",
      "cases": [
        {
          "when": {
            "condition_type": "Morphology_Elongation",
            "params": {
              "operator": ">=",
              "threshold": 1.5
            }
          },
          "apply": {
            "mode": "division",
            "parent_type": "CellB",
            "child_type": "CellB",
            "volume_ratio": 0.5,
            "placement": {
              "type": "random"
            }
          }
        }
      ],
      "once": true,
      "debug": false,
      "triggered": false
    }
  ],
  "celltype_params": {
    "Cell": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    },
    "CellA": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    },
    "CellB": {
      "targetVolume": 49.0,
      "lambdaVolume": 7.0,
      "initial_count": 5,
      "should_initialize": true
    }
  },
  "field_params": {
    "Oxygen": {
      "solver": "DiffusionSolverFE",
      "diffusion_constant": 0.9,
      "decay_constant": 1e-05,
      "initial_expression": "x/100",
      "boundary_conditions": {
        "X": {
          "type": "ConstantValue",
          "min_val": 0.0,
          "max_val": 0.0
        },
        "Y": {
          "type": "ConstantDerivative",
          "min_val": 0.0,
          "max_val": 0.0
        }
      },
      "chemotaxis": [
        {
          "cell_type": "Cell",
          "lambda": 1000.0,
          "mode": "simple",
          "sat_coef": 0.0
        }
      ]
    }
  }
}
{
  "rules": [
    {
      "id": "1",
      "target": "",
      "behaviour": "growth",
      "cases": [
        {
          "when": {
            "condition_type": "Environment",
            "params": {
              "operator": ">",
              "threshold": 0.0,
              "field_name": ""
            }
          },
          "apply": {
            "model": "hill",
            "regulator": "S",
            "parameters": {
              "y_max": 1.0,
              "y_min": 0.0,
              "K": 0.5,
              "n": 2.0
            }
          }
        }
      ],
      "once": false,
      "debug": false,
      "triggered": false
    }
  ],
  "celltype_params": {
    "Cell": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    },
    "CellA": {
      "should_initialize": true,
      "initial_count": 5,
      "targetVolume": 50.0,
      "lambdaVolume": 2.0
    }
  },
  "field_params": {
    "Oxygen": {
      "solver": "DiffusionSolverFE",
      "diffusion_constant": 0.9,
      "decay_constant": 1e-05,
      "initial_expression": "x/100",
      "boundary_conditions": {
        "X": {
          "type": "ConstantValue",
          "min_val": 0.0,
          "max_val": 1.0
        },
        "Y": {
          "type": "ConstantDerivative",
          "min_val": 0.0,
          "max_val": 0.0
        }
      },
      "chemotaxis": {
        "Cell": 1000.0
      }
    },
    "S": {
      "solver": "DiffusionSolverFE",
      "diffusion_constant": 0.5,
      "decay_constant": 0.0001,
      "initial_expression": "0.0",
      "boundary_conditions": {
        "X": {
          "type": "Periodic"
        },
        "Y": {
          "type": "Periodic"
        },
        "Z": {
          "type": "Periodic"
        }
      },
      "chemotaxis": [
        {
          "cell_type": "CellA",
          "lambda": 100.0,
          "mode": "saturation",
          "sat_coef": 2.0
        }
      ]
    }
  }
}